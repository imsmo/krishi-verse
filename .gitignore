# ============================================================================
# Krishi-Verse · root .gitignore (monorepo: pnpm + turbo + Next.js + Expo + Python)
# Goal: commit SOURCE + lockfiles + config; never commit dependencies, build
# output, caches, secrets, or OS/editor cruft. Patterns are repo-wide (they
# match at any depth) unless anchored with a leading slash.
# ============================================================================

# ----------------------------------------------------------------------------
# Dependencies
# ----------------------------------------------------------------------------
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Keep the pnpm lockfile committed (reproducible installs) — do NOT ignore:
#   pnpm-lock.yaml

# ----------------------------------------------------------------------------
# Build output / compiled artifacts
# ----------------------------------------------------------------------------
dist/
build/
out/
lib-cov/
*.tgz

# TypeScript incremental build cache
*.tsbuildinfo
tsconfig.tsbuildinfo

# ----------------------------------------------------------------------------
# Turborepo
# ----------------------------------------------------------------------------
.turbo/

# ----------------------------------------------------------------------------
# Next.js (web-storefront / web-tenant / web-admin / web-partner)
# ----------------------------------------------------------------------------
.next/
next-env.d.ts
.vercel/

# ----------------------------------------------------------------------------
# Expo / React Native (apps/mobile)
# ----------------------------------------------------------------------------
.expo/
.expo-shared/
expo-env.d.ts
web-build/
ios/
android/
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.keystore
!debug.keystore

# Metro
.metro-health-check*
.haste_cache/

# ----------------------------------------------------------------------------
# Python (apps/ai-services)
# ----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
.eggs/
.venv/
venv/
env/
ENV/
.Python
pip-wheel-metadata/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.dmypy.json
.ipynb_checkpoints/

# ----------------------------------------------------------------------------
# Tests / coverage
# ----------------------------------------------------------------------------
coverage/
*.lcov
.nyc_output/
junit.xml
test-results/
playwright-report/
.playwright/

# ----------------------------------------------------------------------------
# Secrets & environment files  (commit ONLY the *.example templates)
# ----------------------------------------------------------------------------
.env
.env.*
*.env
!.env.example
!.env.sample
!.env.template
!.env.*.example

# Cloud / service credentials
*.pem
secrets/
*-credentials.json
gha-creds-*.json

# ----------------------------------------------------------------------------
# Infrastructure as Code (Terraform)
# ----------------------------------------------------------------------------
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.*
*.tfplan
crash.log
crash.*.log
# commit *.tfvars.example, ignore real var files:
*.tfvars
*.tfvars.json
!*.tfvars.example

# Helm packaged charts
charts/**/charts/

# ----------------------------------------------------------------------------
# Logs & runtime
# ----------------------------------------------------------------------------
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.pid
*.seed
*.pid.lock

# ----------------------------------------------------------------------------
# Caches & temp
# ----------------------------------------------------------------------------
.cache/
.eslintcache
.stylelintcache
.parcel-cache/
*.tmp
*.temp
tmp/
temp/

# ----------------------------------------------------------------------------
# OS files
# ----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ----------------------------------------------------------------------------
# Editors / IDEs
# ----------------------------------------------------------------------------
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.recommended.json
*.swp
*.swo
*~
*.sublime-workspace
