# ops/load-tests/pilot/profile.env.example (Sprint S5)
# Copy to `profile.env` (gitignored — it will hold live bearer tokens) and fill in.
#   cp ops/load-tests/pilot/profile.env.example ops/load-tests/pilot/profile.env
# run-pilot-gate.sh sources this file. NEVER commit the filled-in profile.env.

# ── Target ────────────────────────────────────────────────────────────────────────────────────
# MUST be a staging environment. Never point this at a production URL — see README "Money safety".
STAGING_API_URL=https://api.staging.krishiverse.ai
WS_URL=wss://staging-rt.krishiverse.ai

# ── Tenant + identities ──────────────────────────────────────────────────────────────────────
# TENANT_ID: the pilot tenant (scripts/staging-smoke/provision.md Part B creates this).
TENANT_ID=11111111-0000-7000-8000-000000000001

# TOKENS: a pool of "accessToken:refreshToken:userId" triples, comma-separated. Produced by running
#   node ops/load-tests/pilot/provision-loadtest-identities.mjs
# ONCE against this staging environment (see that script's header + README "Setup"). Do NOT put a
# real pilot farmer's session here — these must be dedicated load-test-only identities.
TOKENS=

# LISTING_ID: a published, high-stock listing (auto-seeded by provision-loadtest-identities.mjs)
# that the checkout stage adds to cart. Leave empty to skip the checkout/payment stage entirely
# (order-flow will still exercise the public browse path).
LISTING_ID=

# ── VU-model knobs (see README "VU-model math" for the derivation) ─────────────────────────────
# Sustain: realistic concurrent pilot load. Spike: 2-3x headroom margin. Keep PILOT_MODE=true for
# every pilot-gate run — this is what switches the underlying scripts off their PRD-scale defaults.
PILOT_MODE=true
PILOT_RAMP_MIN=2
PILOT_SUSTAIN_MIN=10
PILOT_SUSTAIN_VUS=20
PILOT_SPIKE_MIN=2
PILOT_SPIKE_VUS=50
PILOT_DRAIN_MIN=1

# Realtime-socket pool sizing (own-order-channel subscribers) — same headroom ratio as HTTP VUs.
PILOT_RT_SUSTAIN_VUS=20
PILOT_RT_SPIKE_VUS=50

# Soak variant (only used when run-pilot-gate.sh is invoked with --soak)
PILOT_SOAK_VUS=15
PILOT_SOAK_DURATION=60m

# ── Thresholds (see README "Thresholds chosen + rationale") ────────────────────────────────────
PILOT_P95_MS=800
PILOT_P99_MS=2000
PILOT_ERR_RATE=0.01
SOAK_P99_MS=2500
SOAK_ERR_RATE=0.01

# ── Behaviour knobs ─────────────────────────────────────────────────────────────────────────────
# Fraction of order-flow iterations that go all the way to checkout+payment-intent (rest just browse).
CHECKOUT_RATE=0.2

# market_intel is OFF by default and not part of the pilot thin slice — leave this false unless you
# have deliberately enabled the `market_intel` flag for this tenant AND supply MARKET_PRODUCT_ID.
INCLUDE_MARKET_PULSE=false
MARKET_PRODUCT_ID=

# ── Money safety (read README before changing anything below) ──────────────────────────────────
# The pilot gate NEVER calls a payment webhook. This var exists only so a human reviewing this file
# sees the invariant stated explicitly; the scripts do not read it.
NEVER_CALL_PAYMENT_WEBHOOK=true
