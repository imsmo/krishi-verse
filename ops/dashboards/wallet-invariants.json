{
  "uid": "krishiverse-wallet",
  "title": "Krishi-Verse \u00b7 Wallet Invariants (MONEY)",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": {}
      }
    ]
  },
  "tags": [
    "krishiverse",
    "p0-6"
  ],
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Reconciliation mismatches (MUST be 0)",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "kv_recon_mismatches{namespace=\"krishiverse\"}",
          "legendFormat": "mismatches"
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Reconciliation age (s)",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "kv_recon_age_seconds{namespace=\"krishiverse\"}",
          "legendFormat": "age"
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "wallet-service RPC failures (5m)",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "increase(dep_failure{dep=\"wallet\"}[5m])",
          "legendFormat": "failures"
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Ledger txn rate",
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(dep_call_count{dep=\"wallet\"}[5m]))",
          "legendFormat": "wallet rpc/s"
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    }
  ]
}