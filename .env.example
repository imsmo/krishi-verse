# Root .env.example — shared defaults TEMPLATE (committed to git: NO real secrets here).
# Copy to .env and fill real local values; .env is gitignored. In staging/prod everything
# comes from AWS Secrets Manager — never from files.
NODE_ENV=development

# Postgres. The apps connect as the least-privilege kv_app role (RLS-enforced), NOT the superuser.
# Migrations/seeds run as the DB owner via MIGRATION_DATABASE_URL.
# NOTE: URL-encode special chars in passwords (e.g. '@' -> %40).
MIGRATION_DATABASE_URL=postgres://<owner_user>:<owner_pw>@localhost:5432/krishiverse
DATABASE_URL=postgres://kv_app:dev@localhost:5432/krishiverse
DATABASE_POOL_MAX=20
SHARD_COUNT=1

REDIS_URL=redis://localhost:6379
OPENSEARCH_URL=http://localhost:9200

# Auth / service secrets — generate strong random values locally (>=32 chars). Do NOT commit real ones.
JWT_ACCESS_SECRET=dev-secret-change-me-min-32-characters
JWT_ISSUER=krishi-verse
JWT_AUDIENCE=krishi-verse-app

# ai-services s2s shared secret (must match ai-services API_SHARED_SECRET)
AI_SERVICES_URL=http://localhost:8000
AI_SERVICES_SHARED_SECRET=change-me-unique-random-min-32-chars

AWS_REGION=ap-south-1
S3_MEDIA_BUCKET=krishi-dev-media

# SMTP (email channel — not yet consumed by any service in this codebase; placeholder for later)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=<your_smtp_user>
SMTP_PASSWORD=<your_smtp_app_password>
EMAIL_FROM=<your_from_address>
