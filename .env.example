# Root .env.example — shared defaults. Each app also has its own .env.example.
NODE_ENV=development
# Postgres (app connects as least-privilege kv_app, never superuser)
DATABASE_URL=postgres://kv_app:kv_app_pw@localhost:5432/krishi_dev
DATABASE_POOL_MAX=20
SHARD_COUNT=1
REDIS_URL=redis://localhost:6379
OPENSEARCH_URL=http://localhost:9200
JWT_ACCESS_SECRET=dev-secret-change-me-min-32-characters
JWT_ISSUER=krishi-verse
AWS_REGION=ap-south-1
S3_MEDIA_BUCKET=krishi-dev-media
