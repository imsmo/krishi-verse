# apps/realtime-gateway/.env.example · realtime gateway
# Fail-closed in production: a weak/missing JWT secret or missing REDIS_URL refuses to start (config.ts).

NODE_ENV=development
REALTIME_PORT=8090

# Redis bus — the api relay publishes projected messages here; the gateway PSUBSCRIBEs to t:*
REDIS_URL=redis://localhost:6379

# Verifies the SAME access JWT the api mints (must match the api's values exactly)
JWT_ACCESS_SECRET=replace-with-a-unique-random-string-at-least-32-chars
JWT_ISSUER=krishi-verse
JWT_AUDIENCE=krishi-verse-app

# Per-socket backpressure limits (protect the pod at scale)
RT_MAX_SUBSCRIPTIONS=50
RT_MAX_BUFFERED_BYTES=1000000
RT_MAX_QUEUED_MESSAGES=100
