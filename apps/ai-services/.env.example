# apps/ai-services/.env.example
# Fail-closed in production: refuses to start without a strong API_SHARED_SECRET (>=32 random chars) and
# INFERENCE_LOG_DB_URL. Provider keys are optional — absent → that path degrades to needs_review (Law 12).

APP_ENV=development

# Service-to-service shared bearer (apps/api / worker / stream-processor present this). MUST be unique random
# >=32 chars in production (a weak value refuses to boot).
API_SHARED_SECRET=replace-with-a-unique-random-string-at-least-32-chars

# Inference audit log (ai_inferences). Connect as a role allowed to set app.tenant_id (kv_relay/kv_app).
INFERENCE_LOG_DB_URL=postgres://kv_relay:dev@localhost:5432/krishiverse

# Optional model providers — degrade to needs_review when unset
ANTHROPIC_API_KEY=
GOOGLE_STT_KEY=

# Tuning
AI_HTTP_TIMEOUT_MS=8000
AI_REQUEST_MAX_BYTES=262144
