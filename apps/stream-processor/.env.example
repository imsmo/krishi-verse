# apps/stream-processor/.env.example
# Fail-closed in production: refuses to start without KAFKA_BROKERS + DATABASE_URL.

NODE_ENV=development
STREAM_HTTP_PORT=8091
STREAM_SHARD_NO=0

# Kafka bus
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=kv-stream-processor

# Postgres — connect as the kv_relay BYPASSRLS role (cross-tenant infra: tail outbox + dedup ledger)
DATABASE_URL=postgres://kv_relay:dev@localhost:5432/krishiverse

# Optional downstreams — degrade to no-op when absent
OPENSEARCH_URL=
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=
OPENSEARCH_INDEX_PREFIX=kv
NOTIFIER_URL=
NOTIFIER_API_KEY=

# Tuning
STREAM_TAIL_BATCH=200
STREAM_CONSUMER_CONCURRENCY=8
STREAM_CONSUMERS=search_indexer,notification_fanout,projection_builder,fraud_signal,view_counter,analytics_etl
