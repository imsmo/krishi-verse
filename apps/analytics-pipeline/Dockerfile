# apps/analytics-pipeline/Dockerfile · multi-stage, non-root. Build context = repo root.
#   docker build -f apps/analytics-pipeline/Dockerfile -t krishi/analytics-pipeline .
FROM node:20-alpine AS build
WORKDIR /repo
RUN corepack enable
COPY pnpm-workspace.yaml package.json turbo.json tsconfig.base.json ./
COPY packages ./packages
COPY apps/analytics-pipeline ./apps/analytics-pipeline
RUN pnpm install --no-frozen-lockfile && pnpm --filter @krishi-verse/analytics-pipeline build

FROM node:20-alpine AS runtime
ENV NODE_ENV=production
WORKDIR /repo
RUN corepack enable && addgroup -S app && adduser -S app -G app
COPY --from=build /repo /repo
USER app
CMD ["node", "apps/analytics-pipeline/dist/main.js"]
