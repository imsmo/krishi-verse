{
  "name": "@krishi-verse/api",
  "version": "0.1.0",
  "private": true,
  "description": "Krishi-Verse API — modular monolith (listings vertical slice fully implemented).",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/main.js",
    "start:dev": "ts-node src/main.ts",
    "test": "jest --config jest.config.js",
    "test:unit": "jest --config jest.config.js --selectProjects unit",
    "test:integration": "jest --config jest.config.js --selectProjects integration",
    "lint": "eslint \"src/**/*.ts\""
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "@nestjs/common": "^10.4.4",
    "@nestjs/core": "^10.4.4",
    "@nestjs/platform-express": "^10.4.4",
    "express": "^4.21.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.12.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.13",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^7.2.1",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  }
}
