# ============================================================
# KRISHI-VERSE API — environment configuration (LOCAL DEV)
# Copy to .env for local work. In staging/prod NONE of these
# live in files — they come from AWS Secrets Manager (see
# infra/terraform/modules/secrets). Law: secrets never in git.
# ============================================================

# apps/api/.env.example — copy to .env for local dev.
NODE_ENV=development
PORT=3000
# App connects as the least-privilege kv_app role (subject to RLS), NOT postgres.
DATABASE_URL=postgres://kv_app:kv_app_pw@localhost:5432/krishi_dev
# Optional dedicated replica; defaults to DATABASE_URL if unset.
# DATABASE_REPLICA_URL=postgres://kv_app:kv_app_pw@localhost:5433/krishi_dev
DATABASE_POOL_MAX=20
SHARD_COUNT=1
JWT_ACCESS_SECRET=dev-secret-change-me-32-chars-min
JWT_ISSUER=krishi-verse
# Optional: absent ⇒ in-memory cache / replica-backed search.
# REDIS_URL=redis://localhost:6379
# OPENSEARCH_URL=http://localhost:9200
# --- integration tests only ---
# Superuser URL used to (re)load the slice schema + create kv_app before tests:
# DATABASE_ADMIN_URL=postgres://postgres:postgres@localhost:5432/krishi_test

# --- outbox relay timer (KV-BL-063) ---
# The api drains the transactional outbox (core/outbox/outbox.dispatcher.ts) on an in-process timer —
# see docs/adr/0001-monorepo-modular-monolith.md's 2026-07-10 amendment. RELAY_DATABASE_URL MUST be the
# kv_relay BYPASSRLS role (migration 0018), never kv_app; empty ⇒ falls back to DATABASE_URL (local
# dev only — assertProductionSecurity requires the kv_relay role name explicitly in production).
RELAY_ENABLED=true
# RELAY_DATABASE_URL=postgres://kv_relay:kv_relay_pw@localhost:5432/krishi_dev
RELAY_POOL_MAX=4
RELAY_INTERVAL_MS=750
RELAY_BATCH_SIZE=100

# --- CORS (ZAP-hardening) ---
# Comma-separated exact origins of the 4 Next.js web apps allowed to read cross-origin responses.
# Empty (default) ⇒ CORS is left off entirely (same as before this var existed). Mobile apps and
# server-to-server webhooks are unaffected either way (no Origin header). REQUIRED in production.
# WEB_ORIGINS=https://sell.krishi-verse.in,https://admin.krishi-verse.in,https://www.krishi-verse.in,https://partners.krishi-verse.in

#--------------------------------------
# extra variable for checking
#--------------------------------------
API_BASE_URL=http://localhost:3000
LOG_LEVEL=debug

# ---- Database (PostgreSQL via docker-compose locally; Aurora+RDS Proxy in prod)
# The api connects as kv_app (RLS enforced, cannot touch ledger).
DATABASE_URL=postgres://kv_app:dev@localhost:5432/krishiverse
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20            # per pod; RDS Proxy multiplexes in prod
DATABASE_STATEMENT_TIMEOUT_MS=5000

# ---- Redis (cache, rate-limit, OTP store) ----
REDIS_URL=redis://localhost:6379
CACHE_DEFAULT_TTL_SECONDS=300

# ---- OpenSearch ----
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_INDEX_PREFIX=kv_dev

# ---- Auth ----
JWT_ACCESS_SECRET=dev-only-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
OTP_LENGTH=6
OTP_TTL_SECONDS=300
OTP_MAX_PER_PHONE_PER_10MIN=3

# ---- AWS (localstack locally) ----
AWS_REGION=ap-south-1
AWS_ENDPOINT=http://localhost:4566     # remove in real AWS
S3_MEDIA_BUCKET=kv-media-dev
SQS_JOBS_QUEUE_URL=http://localhost:4566/000000000000/kv-jobs

# ---- Wallet service (gRPC) — money goes ONLY through here ----
WALLET_GRPC_URL=localhost:50051

# ---- Providers (test keys locally; Secrets Manager in prod) ----
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_WEBHOOK_SECRET=whsec_test_xxx
MSG91_AUTH_KEY=test_xxx
MSG91_SENDER_ID=KRISHI
GUPSHUP_API_KEY=test_xxx           # WhatsApp BSP
KARZA_API_KEY=test_xxx             # KYC/Aadhaar OCR
GOOGLE_STT_KEY=test_xxx            # voice listing fallback
ANTHROPIC_API_KEY=sk-ant-test      # voice→structured listing extraction

# ---- Feature flags / safety ----
FLAGS_REFRESH_SECONDS=30
SMS_DAILY_BUDGET_PAISE=500000      # ₹5,000/day hard cap (cost-bomb defence)
# S2: optional per-locale DLT OTP templates (fallback = MSG91_OTP_TEMPLATE_ID)
MSG91_OTP_TEMPLATE_ID_HI=
MSG91_OTP_TEMPLATE_ID_GU=
MSG91_OTP_TEMPLATE_ID_EN=
