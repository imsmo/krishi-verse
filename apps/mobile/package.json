{
  "name": "@krishi-verse/mobile",
  "version": "0.1.0",
  "private": true,
  "description": "Farmer/Buyer/Worker/Ambassador role-switching app — offline-first, vernacular, low-end devices.",
  "main": "expo-router/entry",
  "scripts": {
    "build:deps": "pnpm --filter @krishi-verse/ui-native build",
    "prestart": "pnpm run build:deps",
    "start": "expo start",
    "preandroid": "pnpm run build:deps",
    "android": "expo run:android",
    "preios": "pnpm run build:deps",
    "ios": "expo run:ios",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "test": "jest --passWithNoTests --runInBand"
  },
  "dependencies": {
    "@babel/runtime": "^7.24.0",
    "@expo-google-fonts/fraunces": "^0.2.3",
    "@expo-google-fonts/hind": "^0.2.3",
    "@expo-google-fonts/plus-jakarta-sans": "^0.2.3",
    "@krishi-verse/i18n": "workspace:*",
    "@krishi-verse/sdk-js": "workspace:*",
    "@krishi-verse/ui-native": "workspace:*",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-native-community/netinfo": "11.3.1",
    "@react-native-voice/voice": "^3.2.4",
    "expo": "~51.0.0",
    "expo-build-properties": "~0.12.5",
    "expo-constants": "~16.0.0",
    "expo-crypto": "~13.0.0",
    "expo-device": "~6.0.2",
    "expo-file-system": "~17.0.1",
    "expo-font": "~12.0.0",
    "expo-image-manipulator": "~12.0.5",
    "expo-image-picker": "~15.0.7",
    "expo-linking": "~6.3.0",
    "expo-localization": "~15.0.0",
    "expo-location": "~17.0.1",
    "expo-notifications": "~0.28.19",
    "expo-router": "~3.5.0",
    "expo-screen-capture": "~6.0.1",
    "expo-secure-store": "~13.0.0",
    "expo-sqlite": "~14.0.6",
    "expo-status-bar": "~1.12.0",
    "react": "^18.3.1",
    "react-native": "^0.74.5",
    "react-native-razorpay": "^2.3.0",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "3.31.1",
    "react-native-svg": "15.2.0"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/react": "^18.3.5",
    "babel-preset-expo": "~11.0.0",
    "eslint": "^8.57.0",
    "eslint-config-expo": "~56.0.4",
    "jest": "^29.7.0",
    "jest-expo": "~51.0.0",
    "typescript": "^5.5.4"
  }
